---
import BaseLayout from '../layouts/BaseLayout.astro';
import InstantSnapshot from '../components/InstantSnapshot.astro';

const pageTitle = 'Digitful - Real Growth Systems';
const pageDescription =
  'Digitful builds strategy, acquisition, and automation systems for businesses that want durable growth.';
const pageCanonical = 'https://digitful.ca/';
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl={pageCanonical}>
  <main>
    <section class="hero">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-xl-9 col-lg-10">
            <div class="hero-copy hero-copy--centered text-center">
              <span class="eyebrow mb-4">Growth systems</span>
              <h1 class="mb-4">Strategy, acquisition, and automation that work together.</h1>
              <p id="typewriter" class="lead mb-4">
                Turn scattered marketing into a clear system.
              </p>
              <div class="hero-actions justify-content-center">
                <a href="/contact/" class="btn btn-primary btn-lg px-4">Book A Strategy Call</a>
                <a href="/what-we-build/" class="btn btn-link-quiet">See What We Build</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-6">
      <div class="container">
        <div class="section-intro">
          <span class="eyebrow mb-3">What we fix</span>
          <h2 class="mb-3">More traffic will not fix a broken system.</h2>
          <p class="mb-0">
            Weak message, messy conversion paths, and slow follow-up keep growth expensive.
          </p>
        </div>

        <div class="detail-grid">
          <div class="detail-card">
            <strong>Weak message</strong>
            <p class="mb-0">If the offer is unclear, everything downstream gets harder.</p>
          </div>
          <div class="detail-card">
            <strong>Leaky conversion path</strong>
            <p class="mb-0">Traffic does not help much when the next step feels vague.</p>
          </div>
          <div class="detail-card">
            <strong>Slow follow-up</strong>
            <p class="mb-0">Manual handoffs create lag, missed leads, and wasted energy.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-6">
      <div class="container">
        <div class="section-intro">
          <span class="eyebrow mb-3">Core offers</span>
          <h2 class="mb-3">Four ways we help.</h2>
          <p class="mb-0">
            Social, SEO, paid ads, and automation.
          </p>
        </div>

        <div class="service-card-grid service-card-grid--offers">
          <a href="/social-media/" class="service-card service-card__link service-card--social">
            <span class="service-card__icon"><i class="bi bi-chat-square-text"></i></span>
            <div>
              <h3>Social Media</h3>
              <p>Content and positioning that support pipeline.</p>
            </div>
          </a>

          <a href="/seo/" class="service-card service-card__link service-card--seo">
            <span class="service-card__icon"><i class="bi bi-search"></i></span>
            <div>
              <h3>SEO</h3>
              <p>Search built around intent and conversion.</p>
            </div>
          </a>

          <a href="/paid-ads/" class="service-card service-card__link service-card--paid">
            <span class="service-card__icon"><i class="bi bi-bullseye"></i></span>
            <div>
              <h3>Paid Ads</h3>
              <p>Paid acquisition with tighter targeting.</p>
            </div>
          </a>

          <a href="/automation/" class="service-card service-card__link service-card--automation">
            <span class="service-card__icon"><i class="bi bi-diagram-3"></i></span>
            <div>
              <h3>Process Automation</h3>
              <p>Workflow design that removes lag and buys back time.</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="py-6">
      <div class="container">
        <div class="section-intro">
          <span class="eyebrow mb-3">Good fit</span>
          <h2 class="mb-3">A good fit for teams that need more clarity.</h2>
          <p class="mb-0">
            Best for businesses with momentum and operational drag.
          </p>
        </div>

        <div class="story-grid">
          <div class="story-card">
            <span class="story-card__icon"><i class="bi bi-rocket-takeoff"></i></span>
            <strong>You already have demand</strong>
            <p>Interest exists, but the system around it is uneven.</p>
          </div>
          <div class="story-card">
            <span class="story-card__icon"><i class="bi bi-graph-up-arrow"></i></span>
            <strong>You need clearer priorities</strong>
            <p>You want signal, not more moving parts.</p>
          </div>
          <div class="story-card">
            <span class="story-card__icon"><i class="bi bi-lightning-charge"></i></span>
            <strong>You want systems your team can run</strong>
            <p>You need fewer manual gaps and cleaner follow-through.</p>
          </div>
        </div>
      </div>
    </section>

    <InstantSnapshot />

    <section class="py-6">
      <div class="container">
        <div class="site-panel p-4 p-md-5 text-center">
          <span class="eyebrow mb-3">Next step</span>
          <h2 class="mb-3">Need a clearer growth system?</h2>
          <p class="mx-auto mb-4" style="max-width: 38rem;">
            Bring the funnel, the bottlenecks, and the questions. We will help you decide what to fix first.
          </p>
          <div class="hero-actions justify-content-center">
            <a href="/contact/" class="btn btn-primary btn-lg px-4">Talk To Digitful</a>
            <a
              href="https://chatgpt.com/g/g-DmZRaiTLa-digitful-marketing-analyst"
              target="_blank"
              rel="noopener"
              class="btn btn-ghost btn-lg px-4"
            >
              Try The Digitful GPT
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
