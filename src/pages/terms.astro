---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Terms of Service - Digitful';
const pageDescription = "Digitful's terms of service and conditions of use.";
const pageCanonical = 'https://digitful.ca/terms/';
---
<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl={pageCanonical}>
  <main>
    <section class="service-hero text-center">
      <div class="container">
        <span class="eyebrow mb-3">Terms</span>
        <h1 class="mb-3">Terms of Service</h1>
        <p class="lead mb-0">The basic terms that apply when you use this site or contact us.</p>
      </div>
    </section>

    <section class="terms-content py-6">
      <div class="container">
        <div class="legal-shell">
          <p class="text-muted-light mb-4">Last updated: {new Date().toLocaleDateString()}</p>

          <h2>Acceptance of Terms</h2>
          <p class="mb-4">
            By accessing or using Digitful's services, you agree to these terms.
          </p>

          <h2>Services</h2>
          <p>Digitful provides services including:</p>
          <ul class="mb-4">
            <li>Social media strategy</li>
            <li>SEO</li>
            <li>Paid advertising</li>
            <li>Process automation</li>
          </ul>

          <h2>Client Responsibilities</h2>
          <p>Clients are responsible for:</p>
          <ul class="mb-4">
            <li>Providing accurate information</li>
            <li>Paying invoices on time</li>
            <li>Following applicable laws and regulations</li>
            <li>Providing necessary access to accounts and tools</li>
          </ul>

          <h2>Limitation of Liability</h2>
          <p class="mb-4">
            Digitful is not liable for indirect, incidental, special, consequential, or punitive
            damages arising from the use of our services.
          </p>

          <h2>Contact</h2>
          <p class="mb-0">
            Questions about these terms can be sent to
            <a href="mailto:ping@digitful.ca" class="link-primary text-decoration-none">ping@digitful.ca</a>.
          </p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
