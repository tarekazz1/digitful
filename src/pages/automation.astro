---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Process Automation - Digitful';
const pageDescription = 'Digitful designs automation systems that remove lag, protect follow-up, and buy back team capacity.';
const pageCanonical = 'https://digitful.ca/automation/';
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl={pageCanonical}>
  <main>
    <section class="service-hero text-center">
      <div class="container">
        <span class="eyebrow mb-3">Process automation</span>
        <h1 class="mb-3">Your team should not be the integration layer.</h1>
        <p class="lead mb-0">
          If leads stall, handoffs break, and repetitive work keeps eating attention, automation is
          not a nice extra. It is operating leverage.
        </p>
      </div>
    </section>

    <section class="service-info py-6">
      <div class="container">
        <div class="service-shell">
          <h2 class="mb-3">What we solve</h2>
          <ul>
            <li>Leads arrive, but follow-up depends on who happened to notice.</li>
            <li>Your team is losing time to repetitive tasks that should already be systemized.</li>
            <li>The tools exist, but the workflow between them is weak or manual.</li>
          </ul>

          <p class="service-copy">
            We build automation around business flow, not automation for its own sake. That means
            clearer triggers, cleaner ownership, and systems the team can trust when volume rises.
          </p>

          <div class="process-grid mt-4">
            <div class="process-step">
              <span class="process-step__number">01</span>
              <strong>Map the workflow</strong>
              <p class="mb-0">Understand where information should move, who owns the step, and where lag begins.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">02</span>
              <strong>Design the automation</strong>
              <p class="mb-0">Create rules, notifications, routing, and follow-up logic that match reality.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">03</span>
              <strong>Protect the handoff</strong>
              <p class="mb-0">Make sure the system remains visible, measurable, and easy for the team to work with.</p>
            </div>
          </div>

          <div class="mt-4">
            <a href="/contact/?service=automation" class="btn btn-primary btn-lg px-4">Talk Automation</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
