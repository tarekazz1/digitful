---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'What We Build - Digitful';
const pageDescription = 'Digitful builds growth systems that connect strategy, acquisition, and automation.';
const pageCanonical = 'https://digitful.ca/what-we-build/';
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl={pageCanonical}>
  <main>
    <section class="service-hero text-center">
      <div class="container">
        <span class="eyebrow mb-3">What we build</span>
        <h1 class="mb-3">Systems built to work.</h1>
        <p class="lead mb-0">
          We build the structure behind the marketing so performance is easier to manage.
        </p>
      </div>
    </section>

    <section class="service-info py-6">
      <div class="container">
        <div class="service-shell">
          <div class="section-intro">
            <h2 class="mb-3">We build systems, not disconnected campaigns.</h2>
            <p class="mb-0">
              The mix changes by business. The principle does not.
            </p>
          </div>

          <div class="service-grid">
            <div class="service-item p-4">
              <h3><i class="bi bi-chat-square-text"></i> Messaging systems</h3>
              <p class="mb-0">Offers and messaging that make the business easier to understand.</p>
            </div>
            <div class="service-item p-4">
              <h3><i class="bi bi-bullseye"></i> Acquisition systems</h3>
              <p class="mb-0">Channels organized around qualified demand.</p>
            </div>
            <div class="service-item p-4">
              <h3><i class="bi bi-funnel"></i> Conversion systems</h3>
              <p class="mb-0">Clearer buyer journeys and stronger handoff.</p>
            </div>
            <div class="service-item p-4">
              <h3><i class="bi bi-diagram-3"></i> Automation systems</h3>
              <p class="mb-0">Workflow logic that reduces lag and protects follow-up.</p>
            </div>
          </div>

          <div class="process-grid mt-4">
            <div class="process-step">
              <span class="process-step__number">01</span>
              <strong>Audit the current chain</strong>
              <p class="mb-0">Find the bottleneck.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">02</span>
              <strong>Design the operating model</strong>
              <p class="mb-0">Clarify the handoffs and priorities.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">03</span>
              <strong>Build and refine</strong>
              <p class="mb-0">Build the pages, workflows, and automations.</p>
            </div>
          </div>

          <blockquote class="mt-4">
            <p class="mb-0">The goal is a system the business can trust and scale.</p>
          </blockquote>

          <div class="mt-4">
            <a href="/contact/" class="btn btn-primary btn-lg px-4">Discuss Your System</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
