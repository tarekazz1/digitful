---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'What We Build - Digitful';
const pageDescription = 'Digitful builds growth systems that connect strategy, acquisition, and automation.';
const pageCanonical = 'https://digitful.ca/what-we-build/';
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl={pageCanonical}>
  <main>
    <section class="service-hero text-center">
      <div class="container">
        <span class="eyebrow mb-3">What we build</span>
        <h1 class="mb-3">Growth systems that stop wasting your team.</h1>
        <p class="lead mb-0">
          We build the structure behind the marketing so performance does not depend on guesswork,
          heroics, or constant reinvention.
        </p>
      </div>
    </section>

    <section class="service-info py-6">
      <div class="container">
        <div class="service-shell">
          <div class="section-intro">
            <h2 class="mb-3">We build engines, not disconnected campaigns.</h2>
            <p class="mb-0">
              The work usually spans offer clarity, funnel flow, acquisition channels, CRM logic,
              reporting, and automation. The exact mix changes. The principle does not.
            </p>
          </div>

          <div class="service-grid">
            <div class="service-item p-4">
              <h3><i class="bi bi-chat-square-text"></i> Messaging systems</h3>
              <p class="mb-0">Offers, positioning, and content direction that make the business easier to understand and buy from.</p>
            </div>
            <div class="service-item p-4">
              <h3><i class="bi bi-bullseye"></i> Acquisition systems</h3>
              <p class="mb-0">Organic and paid channels organized around qualified demand rather than raw activity.</p>
            </div>
            <div class="service-item p-4">
              <h3><i class="bi bi-funnel"></i> Conversion systems</h3>
              <p class="mb-0">Cleaner buyer journeys, sharper pages, and stronger handoff into sales or onboarding.</p>
            </div>
            <div class="service-item p-4">
              <h3><i class="bi bi-diagram-3"></i> Automation systems</h3>
              <p class="mb-0">Workflow logic that reduces lag, protects follow-up, and lets the team operate with less drag.</p>
            </div>
          </div>

          <div class="process-grid mt-4">
            <div class="process-step">
              <span class="process-step__number">01</span>
              <strong>Audit the current chain</strong>
              <p class="mb-0">Find the bottleneck between attention, conversion, and follow-through.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">02</span>
              <strong>Design the operating model</strong>
              <p class="mb-0">Clarify who does what, where the handoffs happen, and what the system should optimize for.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">03</span>
              <strong>Build and refine</strong>
              <p class="mb-0">Implement the pages, workflows, automations, and decision loops that make the system usable.</p>
            </div>
          </div>

          <blockquote class="mt-4">
            <p class="mb-0">The point is not to look busy. The point is to build something the business can trust and scale.</p>
          </blockquote>

          <div class="mt-4">
            <a href="/contact/?service=what-we-build" class="btn btn-primary btn-lg px-4">Discuss Your Growth System</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
