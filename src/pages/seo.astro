---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'SEO - Digitful';
const pageDescription = 'Digitful approaches SEO as a demand capture and clarity system, not a reporting exercise.';
const pageCanonical = 'https://digitful.ca/seo/';
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl={pageCanonical}>
  <main>
    <section class="service-hero text-center">
      <div class="container">
        <span class="eyebrow mb-3">SEO</span>
        <h1 class="mb-3">SEO built for the right buyer.</h1>
        <p class="lead mb-0">
          Ranking matters only if the traffic helps the business.
        </p>
      </div>
    </section>

    <section class="service-info py-6">
      <div class="container">
        <div class="service-shell">
          <h2 class="mb-3">What we solve</h2>
          <ul>
            <li>You rank, but for searches that do not lead to serious intent.</li>
            <li>Traffic arrives, but the next step is confusing or weak.</li>
            <li>Reports look active, but the business impact is still missing.</li>
          </ul>

          <p class="service-copy">
            We focus on the SEO work that changes outcomes: structure, intent, and conversion.
          </p>

          <div class="process-grid mt-4">
            <div class="process-step">
              <span class="process-step__number">01</span>
              <strong>Audit intent</strong>
              <p class="mb-0">Map search demand to business goals.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">02</span>
              <strong>Fix structure</strong>
              <p class="mb-0">Improve hierarchy, metadata, and crawl clarity.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">03</span>
              <strong>Strengthen conversion</strong>
              <p class="mb-0">Make sure the page turns intent into action.</p>
            </div>
          </div>

          <div class="mt-4">
            <a href="/contact/?service=seo" class="btn btn-primary btn-lg px-4">Talk SEO</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
