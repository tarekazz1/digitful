---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Paid Ads - Digitful';
const pageDescription = 'Digitful builds paid acquisition systems around qualified demand and clearer conversion paths.';
const pageCanonical = 'https://digitful.ca/paid-ads/';
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl={pageCanonical}>
  <main>
    <section class="service-hero text-center">
      <div class="container">
        <span class="eyebrow mb-3">Paid ads</span>
        <h1 class="mb-3">Paid acquisition should buy signal, not confusion.</h1>
        <p class="lead mb-0">
          More spend does not fix a weak offer or a messy path to conversion. We treat paid media as
          one part of the system, not the entire answer.
        </p>
      </div>
    </section>

    <section class="service-info py-6">
      <div class="container">
        <div class="service-shell">
          <h2 class="mb-3">What we solve</h2>
          <ul>
            <li>Clicks are happening, but lead quality is inconsistent or poor.</li>
            <li>Targeting is broad because the offer and audience are still blurry.</li>
            <li>Spend keeps rising while confidence in the channel keeps falling.</li>
          </ul>

          <p class="service-copy">
            We build paid systems around message clarity, tighter audience logic, and landing paths
            designed to convert. The goal is not more campaign complexity. The goal is cleaner demand.
          </p>

          <div class="process-grid mt-4">
            <div class="process-step">
              <span class="process-step__number">01</span>
              <strong>Clarify the offer</strong>
              <p class="mb-0">Get the promise and audience tight enough that targeting can become intelligent.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">02</span>
              <strong>Build the path</strong>
              <p class="mb-0">Connect creative, targeting, and landing experience so the journey feels coherent.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">03</span>
              <strong>Optimize with context</strong>
              <p class="mb-0">Improve the system using lead quality and conversion reality, not just front-end metrics.</p>
            </div>
          </div>

          <div class="mt-4">
            <a href="/contact/?service=paid-ads" class="btn btn-primary btn-lg px-4">Talk Paid Acquisition</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
