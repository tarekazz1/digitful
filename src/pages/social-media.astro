---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Social Media - Digitful';
const pageDescription = 'Digitful builds social media systems that support positioning, trust, and conversion.';
const pageCanonical = 'https://digitful.ca/social-media/';
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl={pageCanonical}>
  <main>
    <section class="service-hero text-center">
      <div class="container">
        <span class="eyebrow mb-3">Social media</span>
        <h1 class="mb-3">Stop posting into the void.</h1>
        <p class="lead mb-0">
          Social should clarify the brand, support demand, and make the next step easier. If it is
          just feeding the calendar, it is not doing enough.
        </p>
      </div>
    </section>

    <section class="service-info py-6">
      <div class="container">
        <div class="service-shell">
          <h2 class="mb-3">What we solve</h2>
          <ul>
            <li>Engagement looks fine, but it is not moving pipeline or trust.</li>
            <li>Content feels random because the positioning underneath it is weak.</li>
            <li>The team is spending energy on channels that are not helping buyers decide.</li>
          </ul>

          <p class="service-copy">
            We build social media systems around message discipline, buyer relevance, and conversion
            support. That means clearer themes, better content filters, and smarter distribution.
          </p>

          <div class="process-grid mt-4">
            <div class="process-step">
              <span class="process-step__number">01</span>
              <strong>Clarify the message</strong>
              <p class="mb-0">Define what the brand should be known for and what the audience actually cares about.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">02</span>
              <strong>Build the system</strong>
              <p class="mb-0">Create content pillars, operating rhythm, and conversion-aware calls to action.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">03</span>
              <strong>Measure what matters</strong>
              <p class="mb-0">Track movement in qualified attention, inbound interest, and downstream action.</p>
            </div>
          </div>

          <div class="mt-4">
            <a href="/contact/?service=social-media" class="btn btn-primary btn-lg px-4">Talk Social Strategy</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
