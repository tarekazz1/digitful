---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'About Digitful';
const pageDescription =
  'Learn how Digitful approaches strategy, acquisition, and automation for long-term growth.';
const pageCanonical = 'https://digitful.ca/about/';
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl={pageCanonical}>
  <main>
    <section class="service-hero text-center">
      <div class="container">
        <span class="eyebrow mb-3">About Digitful</span>
        <h1 class="mb-3">Built for clarity.</h1>
        <p class="lead mb-0">
          We help businesses build a clearer path to growth.
        </p>
      </div>
    </section>

    <section class="about-content py-6">
      <div class="container">
        <div class="service-shell service-shell--narrow">
          <div class="section-intro">
            <h2 class="mb-3">What we do</h2>
            <p class="mb-0">
              We connect message, demand, conversion, and operations so growth is easier to run.
            </p>
          </div>

          <div class="story-grid">
            <div class="story-card">
              <strong>What we care about</strong>
              <p class="mb-0">Revenue quality, speed, and usable systems.</p>
            </div>
            <div class="story-card">
              <strong>What we avoid</strong>
              <p class="mb-0">Vanity metrics, bloat, and busywork.</p>
            </div>
            <div class="story-card">
              <strong>How we show up</strong>
              <p class="mb-0">Direct, collaborative, and honest.</p>
            </div>
          </div>

          <div class="process-grid mt-4">
            <div class="process-step">
              <span class="process-step__number">01</span>
              <strong>Strategy first</strong>
              <p class="mb-0">We find the real constraint first.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">02</span>
              <strong>Systems over stunts</strong>
              <p class="mb-0">We prefer durable systems to short-lived campaigns.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">03</span>
              <strong>Clarity over theater</strong>
              <p class="mb-0">You should always know what is working and what comes next.</p>
            </div>
          </div>

          <div class="mt-4">
            <a href="/contact/" class="btn btn-primary btn-lg px-4">Talk To Us</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
