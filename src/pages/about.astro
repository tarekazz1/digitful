---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'About Digitful';
const pageDescription =
  'Learn how Digitful approaches strategy, acquisition, and automation for long-term growth.';
const pageCanonical = 'https://digitful.ca/about/';
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl={pageCanonical}>
  <main>
    <section class="service-hero text-center">
      <div class="container">
        <span class="eyebrow mb-3">About Digitful</span>
        <h1 class="mb-3">We are not built to sell noise.</h1>
        <p class="lead mb-0">
          Digitful exists for businesses that want sharper decisions, cleaner systems, and growth
          that can survive after the excitement wears off.
        </p>
      </div>
    </section>

    <section class="about-content py-6">
      <div class="container">
        <div class="service-shell">
          <div class="row g-4">
            <div class="col-lg-7">
              <h2 class="mb-3">Our mission</h2>
              <p class="service-copy">
                We do not sell isolated tactics and call that a strategy. We help businesses connect
                message, acquisition, conversion, and operations so the work compounds instead of
                resetting every month.
              </p>
              <p class="service-copy mb-0">
                The goal is not more busy marketing. The goal is a growth system that gives the team
                clearer leverage.
              </p>
            </div>
            <div class="col-lg-5">
              <div class="story-grid" style="grid-template-columns: 1fr;">
                <div class="story-card">
                  <strong>What we care about</strong>
                  <p class="mb-0">Revenue quality, speed to action, and systems the team can actually run.</p>
                </div>
                <div class="story-card">
                  <strong>What we avoid</strong>
                  <p class="mb-0">Vanity metrics, bloated retainers, and work that looks active but changes nothing.</p>
                </div>
                <div class="story-card">
                  <strong>How we show up</strong>
                  <p class="mb-0">Direct, collaborative, and honest about what is worth fixing first.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="process-grid mt-4">
            <div class="process-step">
              <span class="process-step__number">01</span>
              <strong>Strategy first</strong>
              <p class="mb-0">We define the real constraint before recommending channels or execution.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">02</span>
              <strong>Systems over stunts</strong>
              <p class="mb-0">We prefer durable mechanics to clever campaigns that vanish on impact.</p>
            </div>
            <div class="process-step">
              <span class="process-step__number">03</span>
              <strong>Clarity over theater</strong>
              <p class="mb-0">You should always know what is working, what is stuck, and what comes next.</p>
            </div>
          </div>

          <div class="mt-4">
            <a href="/contact/" class="btn btn-primary btn-lg px-4">Talk To The Team</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
