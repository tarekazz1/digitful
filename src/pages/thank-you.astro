---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Thanks - Digitful';
const pageDescription = 'Thank you for contacting Digitful. We will get back to you soon.';
const pageCanonical = 'https://digitful.ca/thank-you/';
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl={pageCanonical}>
  <main>
    <section class="thank-you py-6 d-flex align-items-center justify-content-center" style="min-height: 70vh;">
      <div class="container text-center">
        <div class="mb-4">
          <i class="bi bi-check-circle-fill text-primary display-1"></i>
        </div>
        <span class="eyebrow mb-3">Message received</span>
        <h1 class="mb-3">Thanks for reaching out.</h1>
        <p class="lead mb-3">We will review what you shared and reply within 1 to 2 business days.</p>
        <p class="text-muted-light mb-4">You will hear from us soon.</p>
        <a href="/" class="btn btn-primary btn-lg">Back To Home</a>
      </div>
    </section>
  </main>
</BaseLayout>
