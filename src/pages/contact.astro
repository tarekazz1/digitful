---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Contact Digitful';
const pageDescription = 'Start a conversation with Digitful about strategy, acquisition, or automation.';
const pageCanonical = 'https://digitful.ca/contact/';
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl={pageCanonical}>
  <main>
    <section class="contact-hero text-center">
      <div class="container">
        <span class="eyebrow mb-3">Contact</span>
        <h1 class="mb-3">Tell us where growth feels stuck.</h1>
        <p class="lead mb-0">
          Share what is working, what is unclear, and what needs attention.
        </p>
      </div>
    </section>

    <section class="contact-form py-6">
      <div class="container">
        <div class="contact-shell">
          <div class="section-intro">
            <h2 class="mb-3">Start the conversation</h2>
            <p class="contact-form__intro mb-0">
              Share what is working, what is unclear, and what needs attention.
            </p>
          </div>

          <form action="https://formsubmit.co/73c5ec076cc55c4aefd536c5f88c3526" method="POST" id="contactForm">
            <div class="row g-4">
              <div class="col-md-6">
                <div class="form-floating">
                  <input type="text" class="form-control" id="name" name="name" placeholder="Your Name" required />
                  <label for="name">Your Name</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-floating">
                  <input type="email" class="form-control" id="email" name="email" placeholder="name@example.com" required />
                  <label for="email">Email Address</label>
                </div>
              </div>
              <div class="col-12">
                <div class="form-floating">
                  <input type="text" class="form-control" id="company" name="company" placeholder="Company Name" />
                  <label for="company">Company Name</label>
                </div>
              </div>
              <div class="col-12">
                <p class="mb-2 text-muted-light">What services are you interested in?</p>
                <div class="row g-2">
                  <div class="col-12 col-md-auto">
                    <button type="button" class="btn btn-outline-light btn-lg w-100 toggle-btn" data-service="social-media">Social Media</button>
                  </div>
                  <div class="col-12 col-md-auto">
                    <button type="button" class="btn btn-outline-light btn-lg w-100 toggle-btn" data-service="seo">SEO</button>
                  </div>
                  <div class="col-12 col-md-auto">
                    <button type="button" class="btn btn-outline-light btn-lg w-100 toggle-btn" data-service="paid-ads">Paid Ads</button>
                  </div>
                  <div class="col-12 col-md-auto">
                    <button type="button" class="btn btn-outline-light btn-lg w-100 toggle-btn" data-service="automation">Automation</button>
                  </div>
                </div>
                <input type="hidden" name="services" id="servicesInput" />
              </div>
              <input type="hidden" name="_next" value="https://digitful.ca/thank-you/" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="hidden" name="source" id="sourceInput" />
              <input type="hidden" name="snapshot_url" id="snapshotUrlInput" />
              <input type="hidden" name="snapshot_strategy" id="snapshotStrategyInput" />
              <input type="text" name="_honey" style="display:none" />
              <div class="col-12">
                <div class="form-floating">
                  <textarea
                    class="form-control"
                    id="message"
                    name="message"
                    placeholder="Tell us about your goals"
                    style="height: 170px"
                    required
                  ></textarea>
                  <label for="message">Tell us about your goals</label>
                </div>
              </div>
              <div class="col-12">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="privacy" name="privacy" required />
                  <label class="form-check-label" for="privacy">
                    I agree to the <a href="/privacy/" class="link-primary text-decoration-none">Privacy Policy</a>
                  </label>
                </div>
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-primary btn-lg w-100">Send Message</button>
              </div>
            </div>
          </form>

          <p class="text-muted-light small mb-0 mt-4">We reply within 1 to 2 business days.</p>
        </div>
      </div>
    </section>

    <section class="py-6">
      <div class="container">
        <div class="service-shell service-shell--narrow">
          <div class="contact-grid">
            <div class="contact-card">
              <span class="contact-card__icon"><i class="bi bi-envelope"></i></span>
              <strong>Email</strong>
              <p class="mb-0"><a href="mailto:ping@digitful.ca" class="link-light text-decoration-none">ping@digitful.ca</a></p>
            </div>
            <div class="contact-card">
              <span class="contact-card__icon"><i class="bi bi-telephone"></i></span>
              <strong>Call</strong>
              <p class="mb-0"><a href="tel:+15797797779" class="link-light text-decoration-none">+1 (579) 779-7779</a></p>
            </div>
            <div class="contact-card">
              <span class="contact-card__icon"><i class="bi bi-globe2"></i></span>
              <strong>Location</strong>
              <p class="mb-0">Remote-first, serving teams across Canada and beyond.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
