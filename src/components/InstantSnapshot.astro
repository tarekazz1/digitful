---
// Instant growth snapshot component.
---

<section id="snapshot" class="py-6">
  <div class="container">
    <div class="snapshot-shell">
      <div class="row g-4 align-items-start">
        <div class="col-lg-5">
          <div class="section-intro mb-0">
            <span class="eyebrow mb-3">Live diagnostic</span>
            <h2 class="mb-3">See the current site the way a growth operator would.</h2>
            <p class="mb-0">
              Run a quick snapshot for performance, SEO, and baseline best-practice issues. It is
              not the full strategy, but it will show you where the obvious drag lives.
            </p>
          </div>
        </div>

        <div class="col-lg-7">
          <form id="snapshot-form" class="snapshot-grid">
            <div>
              <label for="snapshot-url" class="form-label">Website URL</label>
              <input
                type="url"
                id="snapshot-url"
                class="form-control form-control-lg"
                placeholder="https://yourwebsite.com"
                aria-label="Website URL to analyze"
                required
              />
            </div>
            <div>
              <label class="form-label d-block">Priority view</label>
              <div class="d-flex flex-wrap gap-3 pt-2">
                <div class="form-check form-check-inline m-0">
                  <input class="form-check-input" type="radio" name="strategy" id="strategyMobile" value="mobile" checked />
                  <label class="form-check-label" for="strategyMobile">Mobile</label>
                </div>
                <div class="form-check form-check-inline m-0">
                  <input class="form-check-input" type="radio" name="strategy" id="strategyDesktop" value="desktop" />
                  <label class="form-check-label" for="strategyDesktop">Desktop</label>
                </div>
              </div>
            </div>
            <div class="d-flex align-items-end">
              <button type="submit" class="btn btn-primary btn-lg px-4">Analyze Now</button>
            </div>
          </form>

          <div id="snapshot-result" aria-live="polite" class="mt-4"></div>
        </div>
      </div>
    </div>
  </div>

  <script src="/scripts/snapshot.js" is:inline type="module"></script>
</section>
