---
import Logo from './Logo.astro';

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-panel">
      <div class="row g-4 align-items-start">
        <div class="col-lg-5">
          <div class="footer-brand">
            <Logo className="mb-3" maxWidth="108px" />
            <p class="mb-3">
              Strategy, acquisition, and automation for teams that want a clearer, more dependable
              path to growth.
            </p>
            <div class="d-flex flex-wrap gap-3">
              <a href="mailto:ping@digitful.ca" class="social-link">ping@digitful.ca</a>
              <a href="tel:+15797797779" class="social-link">+1 (579) 779-7779</a>
            </div>
          </div>
        </div>
        <div class="col-sm-6 col-lg-3">
          <h5 class="fs-6 text-light mb-3">Explore</h5>
          <ul class="footer-links">
            <li><a href="/what-we-build/">What We Build</a></li>
            <li><a href="/social-media/">Social Media</a></li>
            <li><a href="/seo/">SEO</a></li>
            <li><a href="/paid-ads/">Paid Ads</a></li>
            <li><a href="/automation/">Process Automation</a></li>
          </ul>
        </div>
        <div class="col-sm-6 col-lg-4">
          <h5 class="fs-6 text-light mb-3">Where We Help</h5>
          <ul class="footer-links">
            <li>Your traffic looks active, but pipeline quality is inconsistent.</li>
            <li>Your team is executing tactics without a shared operating system.</li>
            <li>You need strategy, execution, and automation to work together.</li>
          </ul>
          <div class="mt-4">
            <a href="/contact/" class="btn btn-outline-light">Start The Conversation</a>
          </div>
        </div>
      </div>

      <div class="footer-meta">
        <span>&copy; {currentYear} Digitful. Real growth, built deliberately.</span>
        <div class="d-flex flex-wrap gap-3">
          <a href="/privacy/">Privacy Policy</a>
          <a href="/terms/">Terms of Service</a>
        </div>
      </div>
    </div>
  </div>
</footer>
