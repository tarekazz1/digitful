---
import Logo from './Logo.astro';
---

<header class="site-header">
  <nav class="navbar navbar-expand-lg navbar-dark site-nav">
    <div class="container">
      <Logo className="navbar-brand" maxWidth="146px" />
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarMain"
        aria-controls="navbarMain"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarMain">
        <ul class="navbar-nav ms-auto align-items-lg-center gap-3 gap-lg-4">
          <li class="nav-item">
            <a class="nav-link" href="/about/">About</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/what-we-build/">What We Build</a>
          </li>
          <li class="nav-item dropdown">
            <a
              class="nav-link dropdown-toggle"
              href="#"
              id="servicesDropdown"
              role="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
            >
              Services
            </a>
            <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end" aria-labelledby="servicesDropdown">
              <li><a class="dropdown-item" href="/social-media/">Social Media</a></li>
              <li><a class="dropdown-item" href="/seo/">SEO</a></li>
              <li><a class="dropdown-item" href="/paid-ads/">Paid Ads</a></li>
              <li><a class="dropdown-item" href="/automation/">Process Automation</a></li>
            </ul>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/contact/">Contact</a>
          </li>
          <li class="nav-item">
            <a class="btn btn-primary px-4" href="/contact/">Book A Strategy Call</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>
</header>
